                        <li>Patient type predicts likely pathway but doesn't dictate it</li>
                        <li>Quadrants are dynamic - reassess regularly as envelopes change</li>
                        <li>Cue progression must match envelope expansion</li>
                        <li>System envelope constraints (fear, stress, sleep) can limit what tissue envelope can tolerate</li>
                    </ul>
                </div>

                <div style="text-align: center; margin-top: 2rem;">
                    <button onclick="showModule('overview')" class="btn btn-primary">Return to Overview</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Module navigation
        function showModule(moduleId) {
            document.querySelectorAll('.module-section').forEach(section => {
                section.classList.remove('active');
            });
            document.getElementById('module-' + moduleId).classList.add('active');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // Force curve visualization
        const curveData = {
            absorb: {
                peak: 60,
                duration: 350,
                color: '#3b82f6',
                label: 'High Impulse, Low Peak',
                gct: '~500ms'
            },
            feel: {
                peak: 120,
                duration: 200,
                color: '#a855f7',
                label: 'Moderate Both',
                gct: '~300ms'
            },
            attack: {
                peak: 180,
                duration: 100,
                color: '#ec4899',
                label: 'High Peak, Low Impulse',
                gct: '~150ms'
            }
        };

        let currentCue = 'absorb';

        function selectCue(cue) {
            currentCue = cue;
            
            // Update button states
            ['absorb', 'feel', 'attack'].forEach(c => {
                const btn = document.getElementById('btn-' + c);
                if (btn) {
                    if (c === cue) {
                        btn.className = 'btn btn-primary';
                    } else {
                        btn.className = 'btn btn-secondary';
                    }
                }
            });
            
            // Update curve
            drawCurve(cue);
        }

        function drawCurve(cue) {
            const data = curveData[cue];
            const startX = 80;
            const endX = startX + data.duration;
            const baseY = 200;
            const peakY = baseY - data.peak;
            const midX = (startX + endX) / 2;

            // Create path for curve
            const curvePath = `M ${startX} ${baseY} Q ${midX} ${peakY} ${endX} ${baseY}`;
            const pathEl = document.getElementById('curve-path');
            if (pathEl) {
                pathEl.setAttribute('d', curvePath);
                pathEl.setAttribute('stroke', data.color);
            }

            // Create fill
            const fillPath = `${curvePath} L ${endX} ${baseY} L ${startX} ${baseY} Z`;
            const fillEl = document.getElementById('curve-fill');
            if (fillEl) {
                fillEl.setAttribute('d', fillPath);
                fillEl.setAttribute('fill', data.color);
            }

            // Update peak marker
            const peakEl = document.getElementById('peak-marker');
            if (peakEl) {
                peakEl.setAttribute('cx', midX);
                peakEl.setAttribute('cy', peakY);
                peakEl.setAttribute('fill', data.color);
            }

            // Update labels
            const labelEl = document.getElementById('curve-label');
            if (labelEl) {
                labelEl.textContent = data.label;
                labelEl.style.backgroundColor = data.color;
            }

            const gctEl = document.getElementById('gct-label');
            if (gctEl) {
                gctEl.textContent = 'Ground Contact Time: ' + data.gct;
            }
        }

        // Initialize on load
        document.addEventListener('DOMContentLoaded', function() {
            drawCurve('absorb');
        });
    </script>
</body>
</html>
