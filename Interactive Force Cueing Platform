  </div>

  <div class="card-3col">
    <div class="cue-card">
      <div class="cue-card-label absorb">Early Stage</div>
      <div class="card-title" style="font-size:0.85rem;margin-bottom:6px;">Absorb Cues</div>
      <div class="cue-card-quote">"Land soft and slow"</div>
      <ul>
        <li>GCT: ~500ms</li>
        <li>Peak Force: LOW</li>
        <li>Goal: Eccentric control</li>
      </ul>
    </div>
    <div class="cue-card">
      <div class="cue-card-label feel">Mid Stage</div>
      <div class="card-title" style="font-size:0.85rem;margin-bottom:6px;">Feel Cues</div>
      <div class="cue-card-quote">"Feel, then push"</div>
      <ul>
        <li>GCT: ~300ms</li>
        <li>Peak Force: MODERATE</li>
        <li>Goal: SSC development</li>
      </ul>
    </div>
    <div class="cue-card">
      <div class="cue-card-label attack">Late Stage</div>
      <div class="card-title" style="font-size:0.85rem;margin-bottom:6px;">Attack Cues</div>
      <div class="cue-card-quote">"Attack and explode"</div>
      <ul>
        <li>GCT: ~150ms</li>
        <li>Peak Force: HIGH</li>
        <li>Goal: Reactive strength</li>
      </ul>
    </div>
  </div>

  <!-- QUIZ -->
  <div class="quiz-block">
    <div class="card-title">Quick Assessment</div>
    <div class="quiz-q">Scenario: ACL reconstruction patient, 8 weeks post-op, starting plyometrics.</div>
    <div class="quiz-scenario">Which cue is most appropriate for their first drop landing from 20cm height?</div>
    <div id="quiz-opts">
      <button class="quiz-opt" id="qopt-a" onclick="answerQuiz('a')">"Attack the landing and bounce high"</button>
      <button class="quiz-opt" id="qopt-b" onclick="answerQuiz('b')">"Land soft and slow, control the descent"</button>
      <button class="quiz-opt" id="qopt-c" onclick="answerQuiz('c')">"Feel the ground then explode up"</button>
    </div>
    <div id="quiz-feedback" style="display:none;"></div>
    <button class="quiz-reset" id="quiz-reset-btn" style="display:none;" onclick="resetQuiz()">↺ Try Again</button>
  </div>
</div>

<script>
// ── TABS ──
function showTab(id, tabEl) {
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + id).classList.add('active');
  // Find the right tab button
  if (tabEl && tabEl.classList) {
    tabEl.classList.add('active');
  } else {
    // called from nav cards — find by text
    document.querySelectorAll('.tab-btn').forEach(b => {
      if (b.textContent.toLowerCase().includes(id.substring(0,4))) b.classList.add('active');
    });
  }
  window.scrollTo({top:60,behavior:'smooth'});
}

// Wire up nav cards properly
document.querySelectorAll('.nav-card').forEach((card, i) => {
  const tabs = ['force','continuum','isometric','plyometric'];
  card.onclick = function() {
    const tabBtns = document.querySelectorAll('.tab-btn');
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + tabs[i]).classList.add('active');
    tabBtns[i+1].classList.add('active');
    window.scrollTo({top:60,behavior:'smooth'});
  };
});

// ── FORCE CURVE ──
const curves = {
  absorb: { peakY: 50,  midX: 200, endX: 340, color: '#60a5fa', badge: 'High Impulse, Low Peak Force',    gct: '~500ms', cls: 'absorb' },
  feel:   { peakY: 100, midX: 170, endX: 290, color: '#a78bfa', badge: 'Moderate Both',                    gct: '~300ms', cls: 'feel'   },
  attack: { peakY: 145, midX: 130, endX: 230, color: '#ff1a1a', badge: 'Low Impulse, High Peak Force',     gct: '~150ms', cls: 'attack' },
};
let activeCue = 'absorb';

function buildPath(c) {
  const baseY = 180;
  const startX = 50;
  const peakX = c.midX;
  const peakY = baseY - c.peakY;
  const endX = c.endX;
  return {
    line: `M ${startX} ${baseY} C ${startX + 40} ${baseY} ${peakX - 40} ${peakY} ${peakX} ${peakY} S ${endX - 20} ${baseY} ${endX} ${baseY}`,
    fill: `M ${startX} ${baseY} C ${startX + 40} ${baseY} ${peakX - 40} ${peakY} ${peakX} ${peakY} S ${endX - 20} ${baseY} ${endX} ${baseY} L ${startX} ${baseY} Z`
  };
}

function renderCurve(cue) {
  const c = curves[cue];
  const paths = buildPath(c);
  const curvePath = document.getElementById('force-curve');
  const fillPath = document.getElementById('force-fill');
  const dot = document.getElementById('peak-dot');
  curvePath.setAttribute('d', paths.line);
  curvePath.setAttribute('stroke', c.color);
  fillPath.setAttribute('d', paths.fill);
  fillPath.setAttribute('fill', c.color);
  dot.setAttribute('cx', c.midX);
  dot.setAttribute('cy', 180 - c.peakY);
  dot.setAttribute('fill', c.color);
  dot.setAttribute('opacity', '1');
  document.getElementById('curve-badge').textContent = c.badge;
  document.getElementById('curve-badge').className = 'curve-badge ' + c.cls;
  document.getElementById('curve-gct').textContent = 'Ground Contact Time: ' + c.gct;
}

function selectCue(cue) {
  activeCue = cue;
  document.querySelectorAll('.cue-btn').forEach(b => b.className = 'cue-btn');
  document.getElementById('btn-' + cue).classList.add('active-' + cue);
  renderCurve(cue);
}

function animateCurve() {
  const path = document.getElementById('force-curve');
  path.classList.remove('animate-pulse-once');
  void path.offsetWidth;
  path.classList.add('animate-pulse-once');
}

// Init curve
renderCurve('absorb');

// ── CONTINUUM ──
const continuumInfo = {
  absorb: { title: 'ABSORB', color: 'var(--blue)', desc: 'Compliant tendon, longer contact time, controlled deceleration. Use in early rehab when tissue tolerance is the limiting factor.', cues: ['"Land like a feather"','"Soft and slow"','"Sink into the landing"'] },
  feel:   { title: 'FEEL',   color: '#a78bfa',     desc: 'Moderate intent — beginning to increase stiffness. Transition phase between absorption and explosive demands.', cues: ['"Meet the ground"','"Feel the platform"','"Pop off"'] },
  attack: { title: 'ATTACK', color: 'var(--red2)',  desc: 'Stiff tendon, short contact time, high peak force. Use in late-stage rehab and performance contexts when tissue is ready.', cues: ['"Attack the ground"','"Explode through"','"Rip the floor"'] },
};

function highlightContinuum(type) {
  const info = continuumInfo[type];
  document.getElementById('continuum-detail').innerHTML = `
    <div style="background:var(--black2);border:1px solid var(--border);border-left:3px solid ${info.color};border-radius:4px;padding:16px;">
      <div style="font-size:0.65rem;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:${info.color};margin-bottom:8px;">${info.title}</div>
      <p style="font-size:0.83rem;color:var(--muted);margin-bottom:12px;line-height:1.7;">${info.desc}</p>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        ${info.cues.map(c => `<span style="background:var(--surface);border:1px solid var(--border);border-radius:2px;padding:4px 10px;font-size:0.78rem;color:${info.color};font-style:italic;">${c}</span>`).join('')}
      </div>
    </div>`;
}

// ── QUIZ ──
function answerQuiz(opt) {
  const correct = opt === 'b';
  document.querySelectorAll('.quiz-opt').forEach(b => b.classList.add('disabled'));
  document.getElementById('qopt-' + opt).classList.add(correct ? 'correct' : 'wrong');
  if (!correct) document.getElementById('qopt-b').classList.add('correct');

  const fb = document.getElementById('quiz-feedback');
  fb.style.display = 'block';
  fb.className = 'quiz-feedback ' + (correct ? 'correct' : 'wrong');
  fb.innerHTML = correct
    ? '✓ Correct! Early stage requires absorb cues to build eccentric capacity and tissue tolerance. At 8 weeks post-op, the goal is controlled deceleration — not reactive strength.'
    : 'Not quite. At 8 weeks post-op, focus should be on eccentric control with "absorb" cues before progressing to more aggressive cueing. Tissue tolerance is still the limiting factor.';

  document.getElementById('quiz-reset-btn').style.display = 'inline-block';
}

function resetQuiz() {
  document.querySelectorAll('.quiz-opt').forEach(b => { b.className = 'quiz-opt'; });
  document.getElementById('quiz-feedback').style.display = 'none';
  document.getElementById('quiz-reset-btn').style.display = 'none';
}
</script>
</body>
</html>
