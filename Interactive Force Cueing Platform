<div id="tab-plyometric" class="tab-content">
  <div class="section-eyebrow">Progressive Application</div>
  <div class="section-title">Plyometric Applications</div>

  <div class="card">
    <div class="card-title">Progression Continuum</div>
    <div class="plyo-phases">
      <div class="plyo-phase p1">
        <div class="plyo-phase-name">ECC Absorption</div>
        <div class="plyo-phase-stage">Early Rehab</div>
      </div>
      <div class="plyo-arrow">→</div>
      <div class="plyo-phase p2">
        <div class="plyo-phase-name">Propulsive Dev</div>
        <div class="plyo-phase-stage">Building SSC</div>
      </div>
      <div class="plyo-arrow">→</div>
      <div class="plyo-phase p3">
        <div class="plyo-phase-name">Phasic Coupling</div>
        <div class="plyo-phase-stage">Mid-Late Stage</div>
      </div>
      <div class="plyo-arrow">→</div>
      <div class="plyo-phase p4">
